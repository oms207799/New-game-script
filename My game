-- MORPH FUNCTION (CLIENT ONLY)
local function morphToOwner()
	local char = player.Character
	if not char then return end

	local morphModel = game.ReplicatedStorage:WaitForChild("Morphs"):FindFirstChild("OwnerMorph")
	if not morphModel then
		warn("Morph not found")
		return
	end

	local newChar = morphModel:Clone()
	newChar.Name = player.Name
	newChar.Parent = workspace

	newChar:PivotTo(char:GetPivot())

	player.Character = newChar
end

